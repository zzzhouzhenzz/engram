{
  "_comment": "Copy the 'hooks' block into ~/.claude/settings.json.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "engram_ensure_running",
            "timeout": 15
          },
          {
            "type": "http",
            "url": "http://localhost:7777/hooks/session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:7777/hooks/stop",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
